def hashmap_example():
    scores = {}

    # Add key-value pairs
    scores["Alice"] = 95
    scores["Bob"] = 88
    scores["Charlie"] = 92

    # Get a value by key
    alice_score = scores["Alice"]
    print("Alice:", alice_score)

    # Check if a key exists
    if "Bob" in scores:
        print("Bob is in the map")

    # Update a value
    scores["Bob"] = 90

    # Loop through entries
    for name, score in scores.items():
        print(f"{name} -> {score}")

    # Remove a key
    scores.pop("Charlie", None)

    print("Final map:", scores)


def number_stream(limit):
    """Yields numbers from 0 to limit-1 lazily (stream-like)."""
    for n in range(limit):
        yield n


    # Example usage
    for x in number_stream(5):
        print(x)  # 0, 1, 2, 3, 4


