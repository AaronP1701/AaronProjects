def restoreString(s ="abc" , indices = [0,1,2]):
    """
    :type s: str
    :type indices: List[int]
    :rtype: str
    """
    result = [] 
    dictionary = {}
   
    for i in indices:
        dictionary[indices[i]] = s[i]

    for i in range(len(s)):
        result.append(dictionary[i])

    return ''.join(result)

