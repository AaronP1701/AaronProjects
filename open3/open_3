#include <stdio.h>
#include <sys/types.h>
#include <sys/stat.h>
#include <fcntl.h>
#include <errno.h>

void main (){

    int fd;  
    // fd = open("newFile.log", O_RDWR | O_CREAT, 0774);
    fd = open("newFile2.log", O_RDWR | O_CREAT | O_EXCL, S_IRWXU|S_IRWXG|S_IROTH); //opens file for user, sets the permission

//O_CREAT = create new file

    if ( fd == -1 )
    {
        printf("\n open() has failed - errno = (%d)\n", errno);
        perror("ERROR:");
    }
    else {
        printf("\n open() system call was executed successfully\n");
    }

}